# Anonym X Frontend - Production Environment
# Copy this file to .env and configure for your environment

# Your server URL (IMPORTANT: change to your domain)
EXPO_PUBLIC_BACKEND_URL=https://your-domain.com

# Optional: Custom tunnel subdomain for Expo
# EXPO_TUNNEL_SUBDOMAIN=your-app-name

# Build configuration
EXPO_USE_FAST_RESOLVER="1"
